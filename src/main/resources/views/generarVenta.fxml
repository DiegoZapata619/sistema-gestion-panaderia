<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextFormatter?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="900.0" styleClass="form-container" stylesheets="@../styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.panaderia.controllers.GenerarVentaController">
   <children>
      <VBox layoutX="20.0" layoutY="20.0" prefHeight="660.0" prefWidth="860.0" spacing="15.0">
         <children>
            <Label styleClass="title-text" text="Generar Nueva Venta">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
            
            <!-- Selección de Cliente -->
            <AnchorPane prefHeight="60.0" prefWidth="860.0">
               <children>
                  <Label layoutX="20.0" layoutY="5.0" styleClass="form-label" text="Cliente:" />
                  <ComboBox fx:id="comboClientes" layoutX="80.0" layoutY="20.0" prefHeight="30.0" prefWidth="200.0" styleClass="combo-box" />
               </children>
            </AnchorPane>
            
            <!-- Selección de Producto -->
            <AnchorPane prefHeight="60.0" prefWidth="860.0">
               <children>
                  <Label layoutX="20.0" layoutY="5.0" styleClass="form-label" text="Producto:" />
                  <ComboBox fx:id="comboProductos" layoutX="80.0" layoutY="20.0" prefHeight="30.0" prefWidth="250.0" styleClass="combo-box" />
                  <Label layoutX="350.0" layoutY="5.0" styleClass="form-label" text="Cantidad:" />
                  <TextField fx:id="txtCantidad" layoutX="410.0" layoutY="20.0" prefHeight="30.0" prefWidth="80.0" styleClass="text-field" text="1" />
                  <Button fx:id="btnAgregar" layoutX="510.0" layoutY="20.0" mnemonicParsing="false" onAction="#agregarProducto" prefHeight="30.0" prefWidth="100.0" styleClass="success" text="Agregar" />
               </children>
            </AnchorPane>
            
            <!-- Carrito de Compras -->
            <TableView fx:id="tablaCarrito" prefHeight="300.0" prefWidth="860.0" styleClass="table-container">
              <columns>
                <TableColumn fx:id="colIdProducto" prefWidth="80.0" text="ID" />
                <TableColumn fx:id="colNombreProducto" prefWidth="200.0" text="Producto" />
                <TableColumn fx:id="colPrecioUnitario" prefWidth="100.0" text="Precio U." />
                <TableColumn fx:id="colCantidad" prefWidth="80.0" text="Cantidad" />
                <TableColumn fx:id="colSubtotal" prefWidth="100.0" text="Subtotal" />
                <TableColumn fx:id="colAcciones" prefWidth="100.0" text="Acciones" />
              </columns>
            </TableView>
            
            <!-- Resumen de Venta -->
            <AnchorPane prefHeight="120.0" prefWidth="860.0">
               <children>
                  <VBox layoutX="550.0" layoutY="10.0" prefHeight="100.0" prefWidth="300.0" spacing="10.0">
                     <children>
                        <AnchorPane prefHeight="25.0" prefWidth="300.0">
                           <children>
                              <Label layoutX="0.0" layoutY="0.0" styleClass="form-label" text="Subtotal:" />
                              <Label fx:id="lblSubtotal" layoutX="200.0" layoutY="0.0" styleClass="form-label" text="0.00" />
                           </children>
                        </AnchorPane>
                        <AnchorPane prefHeight="25.0" prefWidth="300.0">
                           <children>
                              <Label layoutX="0.0" layoutY="0.0" styleClass="form-label" text="Descuento:" />
                              <Label fx:id="lblDescuento" layoutX="200.0" layoutY="0.0" styleClass="form-label" text="0.00" />
                           </children>
                        </AnchorPane>
                        <AnchorPane prefHeight="25.0" prefWidth="300.0">
                           <children>
                              <Label layoutX="0.0" layoutY="0.0" styleClass="form-label" text="Total:" />
                              <Label fx:id="lblTotal" layoutX="200.0" layoutY="0.0" styleClass="form-label" text="0.00" />
                           </children>
                        </AnchorPane>
                     </children>
                  </VBox>
                  <VBox layoutX="20.0" layoutY="10.0" prefHeight="100.0" prefWidth="300.0" spacing="10.0">
                     <children>
                        <AnchorPane prefHeight="25.0" prefWidth="300.0">
                           <children>
                              <Label layoutX="0.0" layoutY="0.0" styleClass="form-label" text="Método de Pago:" />
                              <ComboBox fx:id="comboMetodoPago" layoutX="120.0" layoutY="0.0" prefHeight="25.0" prefWidth="150.0" styleClass="combo-box" />
                           </children>
                        </AnchorPane>
                        <AnchorPane prefHeight="25.0" prefWidth="300.0">
                           <children>
                              <Label layoutX="0.0" layoutY="0.0" styleClass="form-label" text="Descuento:" />
                              <ComboBox fx:id="comboDescuento" layoutX="120.0" layoutY="0.0" prefHeight="25.0" prefWidth="150.0" styleClass="combo-box" />
                           </children>
                        </AnchorPane>
                     </children>
                  </VBox>
               </children>
            </AnchorPane>
            
            <!-- Botones de Acción -->
            <AnchorPane prefHeight="60.0" prefWidth="860.0">
               <children>
                  <Button fx:id="btnConfirmar" layoutX="550.0" layoutY="15.0" mnemonicParsing="false" onAction="#confirmarVenta" prefHeight="30.0" prefWidth="120.0" styleClass="success large" text="Confirmar Venta" />
                  <Button fx:id="btnCancelar" layoutX="690.0" layoutY="15.0" mnemonicParsing="false" onAction="#cancelarVenta" prefHeight="30.0" prefWidth="120.0" styleClass="danger large" text="Cancelar" />
                  <Button fx:id="btnVaciar" layoutX="400.0" layoutY="15.0" mnemonicParsing="false" onAction="#vaciarCarrito" prefHeight="30.0" prefWidth="120.0" styleClass="warning" text="Vaciar Carrito" />
               </children>
            </AnchorPane>
         </children>
      </VBox>
   </children>
</AnchorPane>
