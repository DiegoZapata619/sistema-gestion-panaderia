<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="399.0" prefWidth="565.0" stylesheets="@../styles.css"
            styleClass="form-container"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.panaderia.controllers.ClienteController">

    <children>

        <TableView fx:id="tablaClientes" layoutX="20.0" layoutY="20.0" prefHeight="200.0" prefWidth="525.0" styleClass="table-container">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="120" text="Nombre" />
                <TableColumn fx:id="colTelefono" prefWidth="120" text="Teléfono" />
                <TableColumn fx:id="colPuntos" prefWidth="80" text="Puntos" />
                <TableColumn fx:id="colVisitas" prefWidth="80" text="Visitas" />
                <TableColumn fx:id="colCorreo" prefWidth="150" text="Correo" />
                <TableColumn fx:id="colPreferencias" prefWidth="150" text="Preferencias" />
            </columns>
        </TableView>

        <TextField fx:id="txtId" layoutX="30" layoutY="240" promptText="ID" prefWidth="120" />
        <TextField fx:id="txtNombre" layoutX="30" layoutY="270" promptText="Nombre" prefWidth="120" />
        <TextField fx:id="txtTelefono" layoutX="30" layoutY="300" promptText="Teléfono" prefWidth="120" />
        <TextField fx:id="txtCorreo" layoutX="30" layoutY="330" promptText="Correo" prefWidth="120" />
        <TextField fx:id="txtPreferencias" layoutX="30" layoutY="360" promptText="Preferencias" prefWidth="120" />

        <Button layoutX="180" layoutY="270" onAction="#agregarCliente" text="Agregar" styleClass="success" prefWidth="100" />
        <Button layoutX="180" layoutY="310" onAction="#eliminarCliente" text="Eliminar" styleClass="danger" prefWidth="100" />

    </children>
</AnchorPane>
