<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="399.0" prefWidth="565.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.panaderia.controllers.ClienteController">

    <children>

        <TableView fx:id="tablaClientes" layoutX="12.0" layoutY="21.0" prefHeight="201.0" prefWidth="534.0">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="120" text="Nombre" />
                <TableColumn fx:id="colTelefono" prefWidth="120" text="Teléfono" />
                <TableColumn fx:id="colPuntos" prefWidth="80" text="Puntos" />
                <TableColumn fx:id="colVisitas" prefWidth="80" text="Visitas" />
                <TableColumn fx:id="colCorreo" prefWidth="150" text="Correo" />
                <TableColumn fx:id="colPreferencias" prefWidth="150" text="Preferencias" />
            </columns>
        </TableView>

        <TextField fx:id="txtId" layoutX="20" layoutY="240" promptText="ID" />
        <TextField fx:id="txtNombre" layoutX="20" layoutY="270" promptText="Nombre" />
        <TextField fx:id="txtTelefono" layoutX="20" layoutY="300" promptText="Teléfono" />
        <TextField fx:id="txtCorreo" layoutX="20" layoutY="330" promptText="Correo" />
        <TextField fx:id="txtPreferencias" layoutX="20" layoutY="360" promptText="Preferencias" />

        <Button layoutX="250" layoutY="270" onAction="#agregarCliente" text="Agregar" />
        <Button layoutX="250" layoutY="310" onAction="#eliminarCliente" text="Eliminar" />

    </children>
</AnchorPane>
