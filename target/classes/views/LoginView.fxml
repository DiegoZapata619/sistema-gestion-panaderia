<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="500.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.panaderia.controllers.LoginController" >
   <children>

              <Label alignment="TOP_CENTER"
                     layoutX="64.0" layoutY="207.0"
                     prefHeight="42.0" prefWidth="270.0"
                     text="INICIO DE SESIÓN">
         <font>
            <Font name="Segoe UI Bold" size="30.0" />
         </font>
      </Label>
       <Button layoutX="153.0" layoutY="406.0" text="Continuar" onAction="#inicioSesion" >
         <font>
            <Font name="Segoe UI Symbol" size="16.0" />
         </font>
       </Button>
      <TextField fx:id="TxtUsuario"
              layoutX="69.0" layoutY="288.0"
              prefHeight="26.0" prefWidth="259.0" />
      <ImageView fitHeight="140.0" fitWidth="140.0" layoutX="130.0" layoutY="42.0">
         <image>
            <Image url="@../images/295128.png" />
         </image>
      </ImageView>
      <Text layoutX="70.0" layoutY="282.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Usuario">
         <font>
            <Font name="Segoe UI Semibold" size="22.0" />
         </font>
      </Text>
      <PasswordField fx:id="TxtPassword"
              layoutX="69.0" layoutY="357.0"
              prefHeight="26.0" prefWidth="259.0" />
      <Text layoutX="69.0" layoutY="349.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Contraseña">
         <font>
            <Font name="Segoe UI Semibold" size="22.0" />
         </font>
      </Text>
       <Label fx:id="lblMensaje"/>
   </children>
</AnchorPane>
